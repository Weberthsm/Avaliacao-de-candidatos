# Banco de dados PostgreSQL
DATABASE_URL="postgresql://avaliacao:avaliacao@localhost:5432/avaliacao?schema=public"

# Servidor
PORT=3000

# Autenticação JWT
JWT_SECRET="troque-este-segredo-em-producao"
# Janela de INATIVIDADE do token de acesso (sessão deslizante — ADR-017).
# A cada requisição autenticada o token é renovado, reiniciando esta contagem.
JWT_EXPIRES_IN="30m"
JWT_REFRESH_SECRET="troque-este-segredo-refresh-em-producao"
JWT_REFRESH_EXPIRES_IN="7d"

# Regras de acesso
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Usuário administrador inicial (seed)
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@avaliacao.local"
ADMIN_PASSWORD="Admin@123"
